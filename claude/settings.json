  "model": "opus",
  "enableAllProjectMcpServers": false,
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'UserPromptSubmit hook triggered!'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "nohup terminal-notifier -title 'Claude Code' -subtitle 'Needs attention' -message 'Waiting for your input' -sound Ping -group claude-notification -activate com.mitchellh.ghostty -ignoreDnD >/dev/null 2>&1 &"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "nohup terminal-notifier -title 'Claude Code' -subtitle 'Task complete' -message 'Finished processing' -sound Pop -group claude-stop -activate com.mitchellh.ghostty -ignoreDnD >/dev/null 2>&1 &"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bunx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "git-workflow@claude-code-templates": false,
    "commit-commands@claude-code-plugins": false,
    "feature-dev@claude-code-plugins": false,
    "claude-mem@thedotmack": false,
    "canvas@claude-canvas": false,
    "frontend-design@claude-code-plugins": true,
    "dev-browser@dev-browser-marketplace": true,
    "ralph-wiggum@claude-code-plugins": true,
    "claude-notifications-go@claude-notifications-go": true
  },
  "extraKnownMarketplaces": {
    "claude-notifications-go": {
      "source": {
        "source": "github",
        "repo": "777genius/claude-notifications-go"
      }
    }
  },
  "outputStyle": "default",
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true
}
